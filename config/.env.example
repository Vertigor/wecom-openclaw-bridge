# ==========================================
# 企业微信消息转发系统 - 配置文件
# 请将此文件复制为 .env 并填入实际配置
# ==========================================

# ------------------------------------------
# 服务端配置 (Server)
# ------------------------------------------
# 企业微信智能机器人的 BotID
WECOM_BOT_ID=YOUR_BOT_ID

# 企业微信智能机器人的 Secret
WECOM_BOT_SECRET=YOUR_BOT_SECRET

# 服务端 HTTP 接口监听地址和端口
SERVER_HOST=0.0.0.0
SERVER_PORT=8765

# 内存消息队列最大容量
MAX_QUEUE_SIZE=1000

# WebSocket 心跳间隔（秒）
WS_HEARTBEAT_INTERVAL_SECONDS=30

# WebSocket 断线重连初始延迟（秒）
WS_RECONNECT_DELAY_SECONDS=5


# ------------------------------------------
# 客户端配置 (Client)
# ------------------------------------------
# 服务端 HTTP 接口地址
SERVER_BASE_URL=http://127.0.0.1:8765

# 轮询间隔（秒）
POLL_INTERVAL_SECONDS=3

# 单次轮询最多拉取的消息数量
POLL_BATCH_SIZE=50

# OpenClaw Gateway 地址
OPENCLAW_BASE_URL=http://127.0.0.1:18789

# OpenClaw Gateway 认证 Token (对应 gateway.auth.token)
OPENCLAW_GATEWAY_TOKEN=YOUR_OPENCLAW_TOKEN

# 目标会话 Key
OPENCLAW_SESSION_KEY=main

# (可选) 传递给 OpenClaw 的 Channel 上下文提示
OPENCLAW_CHANNEL_HINT=wecom

# HTTP 请求超时时间（秒）
HTTP_TIMEOUT_SECONDS=10
