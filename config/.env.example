# ==========================================
# 企业微信消息转发系统 - 配置文件
# 请将此文件复制为 .env 并填入实际配置
# cp config/.env.example config/.env
# ==========================================

# ------------------------------------------
# 服务端配置 (Server)
# ------------------------------------------

# 企业微信智能机器人的 BotID（在企业微信管理后台获取）
WECOM_BOT_ID=YOUR_BOT_ID

# 企业微信智能机器人的长连接专用 Secret
WECOM_BOT_SECRET=YOUR_BOT_SECRET

# 服务端 HTTP 接口监听地址和端口
SERVER_HOST=0.0.0.0
SERVER_PORT=8765

# 内存消息队列最大容量（超出后自动丢弃最旧的消息）
MAX_QUEUE_SIZE=1000

# WebSocket 心跳间隔（秒），建议 30 秒
WS_HEARTBEAT_INTERVAL_SECONDS=30

# WebSocket 断线重连初始延迟（秒），每次失败后翻倍，最长 60 秒
WS_RECONNECT_DELAY_SECONDS=5


# ------------------------------------------
# 客户端配置 (Client)
# ------------------------------------------

# 服务端 HTTP 接口基础地址（不含尾部斜杠）
SERVER_BASE_URL=http://127.0.0.1:8765

# 轮询间隔（秒），扣除本轮处理耗时后的实际等待时间
POLL_INTERVAL_SECONDS=3

# 单次轮询最多拉取的消息数量
POLL_BATCH_SIZE=50

# HTTP 请求超时时间（秒）
HTTP_TIMEOUT_SECONDS=10

# ------------------------------------------
# OpenClaw Gateway 配置
# ------------------------------------------

# OpenClaw Gateway 基础地址（不含尾部斜杠）
OPENCLAW_BASE_URL=http://127.0.0.1:18789

# OpenClaw Gateway Bearer Token（对应 gateway.auth.token 配置项）
OPENCLAW_GATEWAY_TOKEN=YOUR_OPENCLAW_TOKEN

# 发送给 POST /v1/responses 的 model 字段值
# 通常填写 OpenClaw 配置的 model 名称，默认为 openclaw
OPENCLAW_MODEL=openclaw

# (可选) 系统指令，作为 AI 角色设定（instructions 字段）
# 为空则使用 OpenClaw 自身默认的 system prompt
OPENCLAW_SYSTEM_PROMPT=

# (可选) Channel 标识，作为 x-openclaw-message-channel 请求头
# 用于 OpenClaw 内部路由到指定 Channel，为空则不附加
OPENCLAW_CHANNEL_HINT=wecom

# 调用 OpenClaw /v1/responses 的超时时间（秒）
# AI 推理可能耗时较长，建议设置为 60 秒或以上
OPENCLAW_TIMEOUT_SECONDS=60

# 用户首次进入会话时的欢迎语（不经过 OpenClaw 处理，直接回复）
OPENCLAW_WELCOME_MESSAGE=您好！我是 AI 智能助手，有什么可以帮您的吗？
